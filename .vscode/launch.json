        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {"CUDA_VISIBLE_DEVICES": "1",
                    "HF_HOME": "${workspaceFolder}/pretrained/transformers",
                    "HUGGINGFACE_HUB_CACHE": "${workspaceFolder}/pretrained/huggingface_hub",
                    "XDG_CACHE_HOME": "${workspaceFolder}/pretrained/clips",},
            "args": ["--task", "train",
                     "--config", "configs/flowmatch/isic/rlpimagegaussian_imagerlp.yaml", 
                     "--exp_name", "debug", 
                     "--device", "cuda",
                     "--learn_obj", "recflow"]
        }
    ]
}



